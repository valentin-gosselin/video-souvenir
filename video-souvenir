def detect_folder_lut(folder):
    """Cherche un .cube dans le dossier source. Prefere look.cube."""
    folder = Path(folder)
    cubes = sorted(folder.glob('*.cube'))
    if not cubes:
        return None
    preferred = next((p for p in cubes if p.stem.lower() == 'look'), None)
    return str(preferred or cubes[0])


def style_filters_mlt(preset_name, custom_lut_path, esc):
    """Renvoie la liste de lignes XML <filter> a inserer dans le tractor V1."""
    lines = []
    if preset_name == 'custom':
        if custom_lut_path:
            lines.append('    <filter id="filter_style_lut3d">')
            lines.append('      <property name="mlt_service">avfilter.lut3d</property>')
            lines.append(f'      <property name="av.file">{esc(custom_lut_path)}</property>')
            lines.append('      <property name="kdenlive_id">avfilter.lut3d</property>')
            lines.append('    </filter>')
        return lines
    preset = STYLE_PRESETS.get(preset_name)
    if not preset:
        return lines
    idx = 0
    if 'eq' in preset:
        lines.append(f'    <filter id="filter_style_eq_{idx}">')
        lines.append('      <property name="mlt_service">avfilter.eq</property>')
        for k, v in preset['eq'].items():
            lines.append(f'      <property name="av.{k}">{v}</property>')
        lines.append('      <property name="kdenlive_id">avfilter.eq</property>')
        lines.append('    </filter>')
        idx += 1
    if 'colorbalance' in preset:
        lines.append(f'    <filter id="filter_style_colorbalance_{idx}">')
        lines.append('      <property name="mlt_service">avfilter.colorbalance</property>')
        for k, v in preset['colorbalance'].items():
            lines.append(f'      <property name="av.{k}">{v}</property>')
        lines.append('      <property name="kdenlive_id">avfilter.colorbalance</property>')
        lines.append('    </filter>')
    return lines


def style_filter_ffmpeg(preset_name, custom_lut_path):
    """Renvoie une chaine de filtres ffmpeg a inserer apres scale (vide si neutre)."""
    if preset_name == 'custom':
        if custom_lut_path:
            return f"lut3d='{custom_lut_path}'"
        return ''
    preset = STYLE_PRESETS.get(preset_name)
    if not preset:
        return ''
    chain = []
    if 'eq' in preset:
        params = ':'.join(f'{k}={v}' for k, v in preset['eq'].items())
        chain.append(f'eq={params}')
    if 'colorbalance' in preset:
        params = ':'.join(f'{k}={v}' for k, v in preset['colorbalance'].items())
        chain.append(f'colorbalance={params}')
    return ','.join(chain)


# Fichiers auto-generes par ce script - a exclure du scan
GENERATED_RE = re.compile(r'^souvenir-\d{8}-\d{6}\.(mp4|kdenlive)$', re.IGNORECASE)


def detect_encoder():
    try:
        result = subprocess.run(['ffmpeg', '-hide_banner', '-encoders'],
                                capture_output=True, text=True, timeout=10)
        encoders = result.stdout
    except Exception:
        return None

    try:
        subprocess.run(['nvidia-smi', '-L'], capture_output=True, check=True, timeout=5)
        if 'hevc_nvenc' in encoders:
            return 'nvenc'
    except Exception:
        pass

    has_dri = Path('/dev/dri/renderD128').exists()
    if has_dri and 'hevc_qsv' in encoders:
        return 'qsv'
    if has_dri and 'hevc_vaapi' in encoders:
        return 'vaapi'
    if 'libx265' in encoders:
        return 'x265'
    return None


def _strength_thresholds(strength):
    """Map agressivite 0-100 vers les seuils silence/black/blur."""
    if strength <= 0:
        return None
    s = max(0, min(100, strength)) / 100.0
    return {
        'silence_min_sec': 2.0 - 1.8 * s,
        'silence_db': -30,
        'black_min_sec': 0.5 - 0.4 * s,
        'black_pix_th': 0.10,
        'blur_var_th': 15 + 35 * s,
        'edge_probe_count': 5,
        'edge_probe_step': 0.4,
    }


def _parse_silence_edges(stderr, duration):
    """Parse ffmpeg silencedetect output -> (trim_in, trim_out) candidates."""
    starts = [float(m.group(1)) for m in re.finditer(r'silence_start:\s*(-?[\d.]+)', stderr)]
    ends_data = re.findall(r'silence_end:\s*([\d.]+)\s*\|\s*silence_duration:\s*([\d.]+)', stderr)
    trim_in = 0.0
    trim_out = duration
    # silence touchant le debut
    if ends_data:
        first_end, first_dur = float(ends_data[0][0]), float(ends_data[0][1])
        if first_end - first_dur <= 0.05:
            trim_in = first_end
    # silence touchant la fin
    if starts:
        last_start = starts[-1]
        # un silence qui demarre et n'a jamais de end -> jusqu'a la fin du clip
        if len(starts) > len(ends_data) and last_start < duration:
            trim_out = last_start
        elif ends_data:
            last_end = float(ends_data[-1][0])
            if last_end >= duration - 0.1 and last_start < duration:
                trim_out = last_start
    return trim_in, trim_out


def _detect_silence_edges(path, duration, db, min_sec):
    cmd = ['ffmpeg', '-nostdin', '-hide_banner', '-i', str(path),
           '-af', f'silencedetect=n={db}dB:d={min_sec}', '-vn', '-f', 'null', '-']
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
        return _parse_silence_edges(r.stderr, duration)
    except Exception:
        return 0.0, duration


def _parse_black_edges(stderr, duration):
    pairs = re.findall(r'black_start:\s*([\d.]+)\s+black_end:\s*([\d.]+)', stderr)
    trim_in = 0.0
    trim_out = duration
    if pairs:
        first_start, first_end = float(pairs[0][0]), float(pairs[0][1])
        if first_start <= 0.05:
            trim_in = first_end
        last_start, last_end = float(pairs[-1][0]), float(pairs[-1][1])
        if last_end >= duration - 0.1:
            trim_out = last_start
    return trim_in, trim_out


def _detect_black_edges(path, duration, min_sec, pix_th):
    cmd = ['ffmpeg', '-nostdin', '-hide_banner', '-i', str(path),
           '-vf', f'blackdetect=d={min_sec}:pix_th={pix_th}', '-an', '-f', 'null', '-']
    try:
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=120)
        return _parse_black_edges(r.stderr, duration)
    except Exception:
        return 0.0, duration


def _laplacian_variance(png_bytes):
    """Variance Laplacienne d'une frame PNG. Plus c'est haut, plus c'est net."""
    try:
        from PIL import Image
        import numpy as np
    except ImportError:
        return None
    try:
        img = Image.open(io.BytesIO(png_bytes)).convert('L')
        arr = np.asarray(img, dtype=np.float32)
        # 3x3 Laplacian kernel approx via difference of neighbours
        lap = (-4 * arr[1:-1, 1:-1]
               + arr[:-2, 1:-1] + arr[2:, 1:-1]
               + arr[1:-1, :-2] + arr[1:-1, 2:])
        return float(lap.var())
    except Exception:
        return None


def _extract_frame_png(path, t_sec, scale_w=320):
    cmd = ['ffmpeg', '-nostdin', '-hide_banner', '-loglevel', 'error',
           '-ss', f'{t_sec:.3f}', '-i', str(path),
           '-frames:v', '1', '-vf', f'scale={scale_w}:-1',
           '-f', 'image2', '-vcodec', 'png', '-']
    try:
        r = subprocess.run(cmd, capture_output=True, timeout=15)
        if r.returncode == 0 and r.stdout:
            return r.stdout
    except Exception:
        pass
    return None


def _detect_blur_edges(path, duration, var_th, probe_count, probe_step):
    """Avance depuis le debut tant que les frames sont floues, recule depuis la fin idem."""
    trim_in = 0.0
    trim_out = duration
    # debut
    for k in range(probe_count):
        t = k * probe_step
        if t >= duration / 2:
            break
        png = _extract_frame_png(path, t)
        if png is None:
            break
        v = _laplacian_variance(png)
        if v is None:
            break
        if v >= var_th:
            trim_in = t
            break
        trim_in = t + probe_step
    # fin
    for k in range(probe_count):
        t = duration - (k + 1) * probe_step
        if t <= duration / 2:
            break
        png = _extract_frame_png(path, t)
        if png is None:
            break
        v = _laplacian_variance(png)
        if v is None:
            break
        if v >= var_th:
            trim_out = t + probe_step
            break
        trim_out = t
    return trim_in, trim_out


def analyze_trim(path, duration, strength):
    """Renvoie (in_sec, out_sec, reasons) ou (0, duration, []) si strength=0 ou clip court."""
    th = _strength_thresholds(strength)
    if th is None or duration < 3.0:
        return 0.0, duration, []
    reasons = []
    in_silence, out_silence = _detect_silence_edges(
        path, duration, th['silence_db'], th['silence_min_sec'])
    in_black, out_black = _detect_black_edges(
        path, duration, th['black_min_sec'], th['black_pix_th'])
    in_blur, out_blur = _detect_blur_edges(
        path, duration, th['blur_var_th'], th['edge_probe_count'], th['edge_probe_step'])

    in_pt = max(in_silence, in_black, in_blur)
    out_pt = min(out_silence, out_black, out_blur)

    if in_silence > 0.05:
        reasons.append(f'silence-{in_silence:.1f}s')
    if in_black > 0.05:
        reasons.append(f'black-{in_black:.1f}s')
    if in_blur > 0.05:
        reasons.append(f'blur-{in_blur:.1f}s')
    end_silence = duration - out_silence
    end_black = duration - out_black
    end_blur = duration - out_blur
    if end_silence > 0.05:
        reasons.append(f'silence-fin-{end_silence:.1f}s')
    if end_black > 0.05:
        reasons.append(f'black-fin-{end_black:.1f}s')
    if end_blur > 0.05:
        reasons.append(f'blur-fin-{end_blur:.1f}s')

    # garde-fou : trimmed duration minimum
    if out_pt - in_pt < 1.0:
        return 0.0, duration, ['trim-skipped-too-short']
    return in_pt, out_pt, reasons


CACHE_VERSION = 1


def _cache_path(folder):
    return Path(folder) / '.video-souvenir-cache.json'


def _load_trim_cache(folder):
    p = _cache_path(folder)
    try:
        data = json.loads(p.read_text(encoding='utf-8'))
        if data.get('version') == CACHE_VERSION:
            return data.get('entries', {})
    except Exception:
        pass
    return {}


def _save_trim_cache(folder, entries):
    p = _cache_path(folder)
    try:
        p.write_text(json.dumps(
            {'version': CACHE_VERSION, 'entries': entries}, indent=2), encoding='utf-8')
    except Exception:
        pass


def _cache_key(path):
    """Cle stable = nom + mtime + taille. Ne pas hasher le contenu (couteux)."""
    p = Path(path)
    try:
        st = p.stat()
        return f'{p.name}|{int(st.st_mtime)}|{st.st_size}'
    except OSError:
        return None


def probe_video(path):
    try:
        cmd = ['ffprobe', '-v', 'error', '-print_format', 'json',
               '-show_format', '-show_streams', str(path)]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0 or not result.stdout.strip():
            return None
        data = json.loads(result.stdout)
    except Exception:
        return None

    info = {'path': str(path), 'name': Path(path).name,
            'width': 0, 'height': 0, 'duration': 0.0, 'creation_time': None,
            'in_point': 0.0, 'out_point': 0.0, 'trim_reasons': []}

    fmt = data.get('format', {})
    try:
        info['duration'] = float(fmt.get('duration', 0) or 0)
    except (TypeError, ValueError):
        pass

    tags = fmt.get('tags', {}) or {}
    info['creation_time'] = tags.get('creation_time')

    for s in data.get('streams', []):
        if s.get('codec_type') == 'video':
            info['width'] = s.get('width', 0) or 0
            info['height'] = s.get('height', 0) or 0
            break

    if not info['creation_time']:
        mtime = datetime.datetime.fromtimestamp(Path(path).stat().st_mtime)
        info['creation_time'] = mtime.isoformat()

    info['out_point'] = info['duration']
    return info


def is_source_video(path):
    p = Path(path)
    return (p.is_file()
            and p.suffix.lower() in VIDEO_EXTS
            and not GENERATED_RE.match(p.name))


def trimmed_duration(clip):
    return max(0.0, clip['out_point'] - clip['in_point'])


def detect_scenes(path, in_point, out_point, threshold=27.0, min_scene_len_sec=2.5,
                  max_duration=120.0):
    """Detecte les scenes via PySceneDetect dans la range. Renvoie liste (in, out) en secondes.
    Downscale auto 4x sur 4K pour rester rapide. Bail sur clips trop longs (>max_duration)."""
    if out_point - in_point > max_duration:
        return None  # delegue au fixed-split
    try:
        from scenedetect import SceneManager, open_video, ContentDetector
    except ImportError:
        return None
    try:
        video = open_video(str(path))
        fr = float(video.frame_rate or 30)
        # Downscale agressif pour vitesse, surtout en 4K
        try:
            w, h = video.frame_size
            if max(w, h) >= 3000:
                video.set_downscale_factor(4)
            elif max(w, h) >= 1500:
                video.set_downscale_factor(2)
        except Exception:
            pass
        sm = SceneManager()
        sm.add_detector(ContentDetector(
            threshold=threshold, min_scene_len=max(1, int(min_scene_len_sec * fr))))
        try:
            sm.detect_scenes(video=video, show_progress=False, duration=out_point - in_point)
        except TypeError:
            sm.detect_scenes(video=video, show_progress=False)
        scenes = sm.get_scene_list()
        if not scenes:
            return [(in_point, out_point)]
        cuts = []
        for s in scenes:
            s_in = max(in_point, s[0].seconds if hasattr(s[0], 'seconds') else s[0].get_seconds())
            s_out = min(out_point, s[1].seconds if hasattr(s[1], 'seconds') else s[1].get_seconds())
            if s_out - s_in >= 1.5:
                cuts.append((s_in, s_out))
        return cuts if cuts else [(in_point, out_point)]
    except Exception:
        return None


def _fixed_split(in_pt, out_pt, step=8.0):
    cuts = []
    t = in_pt
    while t < out_pt:
        end = min(t + step, out_pt)
        if end - t >= 1.5:
            cuts.append((t, end))
        t = end
    return cuts


def split_into_subclips(clips, target_minutes, log=print):
    """Si target > 0 et clip > 30s, decoupe en sub-clips via scenedetect (parallele).
    Sinon, un sub-clip = un clip trime."""
    subclips_by_parent = [None] * len(clips)
    to_detect = []
    for parent_idx, c in enumerate(clips):
        in_pt, out_pt = c['in_point'], c['out_point']
        tdur = out_pt - in_pt
        if target_minutes <= 0 or tdur < 30.0:
            subclips_by_parent[parent_idx] = [(in_pt, out_pt)]
        else:
            to_detect.append(parent_idx)
    if to_detect:
        log(f'Scene detection sur {len(to_detect)} clip(s) long(s)...')
        with ThreadPoolExecutor(max_workers=min(4, len(to_detect))) as ex:
            futures = {}
            for parent_idx in to_detect:
                c = clips[parent_idx]
                futures[ex.submit(detect_scenes, c['path'],
                                  c['in_point'], c['out_point'])] = parent_idx
            for fut in as_completed(futures):
                parent_idx = futures[fut]
                c = clips[parent_idx]
                try:
                    cuts = fut.result()
                except Exception:
                    cuts = None
                if not cuts:
                    cuts = _fixed_split(c['in_point'], c['out_point'], step=8.0)
                subclips_by_parent[parent_idx] = cuts
                if len(cuts) > 1:
                    log(f'  {c["name"]}: {len(cuts)} sub-clips')
    subclips = []
    for parent_idx, c in enumerate(clips):
        base = {
            'path': c['path'],
            'name': c['name'],
            'parent_index': parent_idx,
            'duration': c['duration'],
            'creation_time': c['creation_time'],
            'width': c['width'],
            'height': c['height'],
            'trim_reasons': c.get('trim_reasons', []),
        }
        for s_in, s_out in subclips_by_parent[parent_idx] or []:
            sc = dict(base)
            sc['in_point'] = s_in
            sc['out_point'] = s_out
            subclips.append(sc)
    return subclips


def _score_one_subclip(sc, sample_sec=2.0):
    """Score 0-1 : netteté Laplacien + RMS audio sur 2s + duree."""
    path = sc['path']
    in_pt = sc['in_point']
    out_pt = sc['out_point']
    dur = max(0.001, out_pt - in_pt)
    mid = (in_pt + out_pt) / 2
    sharp_norm = 0.5
    png = _extract_frame_png(path, mid)
    if png:
        v = _laplacian_variance(png)
        if v is not None:
            sharp_norm = min(1.0, v / 200.0)
    # Audio sur une fenetre courte au milieu (sample_sec max)
    audio_norm = 0.5
    if dur >= 1.0:
        sample_dur = min(sample_sec, dur)
        sample_start = max(in_pt, mid - sample_dur / 2)
        try:
            cmd = ['ffmpeg', '-nostdin', '-hide_banner', '-ss', f'{sample_start:.3f}',
                   '-i', str(path), '-t', f'{sample_dur:.3f}', '-af', 'volumedetect',
                   '-vn', '-f', 'null', '-']
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=20)
            m = re.search(r'mean_volume:\s*(-?[\d.]+)\s*dB', r.stderr)
            if m:
                v = float(m.group(1))
                audio_norm = max(0.0, min(1.0, (v + 50.0) / 50.0))
        except Exception:
            pass
    dur_factor = min(1.0, dur / 2.0)
    return 0.5 * sharp_norm + 0.3 * audio_norm + 0.2 * dur_factor


def _score_cache_key(sc):
    """Cle stable pour le cache : path + mtime + size + range."""
    base = _cache_key(sc['path'])
    if not base:
        return None
    return f'{base}|{sc["in_point"]:.3f}|{sc["out_point"]:.3f}'


def score_subclips(subclips, folder=None, log=print):
    if not subclips:
        return subclips
    # Charge cache scores
    cache = _load_trim_cache(folder) if folder else {}
    scores_cache = cache.get('_scores', {}) if isinstance(cache, dict) else {}
    to_score = []
    for sc in subclips:
        key = _score_cache_key(sc)
        if key and key in scores_cache:
            sc['score'] = scores_cache[key]
        else:
            to_score.append(sc)
    if to_score:
        log(f'Scoring {len(to_score)} sub-clip(s) (cache: {len(subclips) - len(to_score)})...')
        with ThreadPoolExecutor(max_workers=min(4, len(to_score))) as ex:
            futures = {ex.submit(_score_one_subclip, sc): sc for sc in to_score}
            for fut in as_completed(futures):
                sc = futures[fut]
                try:
                    sc['score'] = fut.result()
                except Exception:
                    sc['score'] = 0.5
                key = _score_cache_key(sc)
                if key:
                    scores_cache[key] = sc['score']
        if folder:
            cache['_scores'] = scores_cache
            _save_trim_cache(folder, cache)
    return subclips


def detect_beats(audio_path, log=print):
    """Renvoie (bpm, beats_sec[]) via librosa. None si librosa absente ou erreur."""
    try:
        import librosa
    except ImportError:
        log("librosa indispo - installe avec: pip install librosa")
        return None
    try:
        y, sr = librosa.load(str(audio_path), sr=22050, mono=True)
        tempo, beat_frames = librosa.beat.beat_track(y=y, sr=sr)
        beats_sec = librosa.frames_to_time(beat_frames, sr=sr)
        return float(tempo), beats_sec.tolist()
    except Exception as e:
        log(f"beat detection failed: {e}")
        return None


def snap_subclips_to_beats(subclips, beats, tolerance=0.3, log=print):
    """Ajuste les out_point/in_point pour aligner les transitions sur les beats les plus proches."""
    if not beats or len(subclips) < 2:
        return subclips
    snapped = 0
    timeline = 0.0
    for i, sc in enumerate(subclips):
        sc['_timeline_start'] = timeline
        timeline += sc['out_point'] - sc['in_point']
    # Itere sur les transitions (entre i et i+1, qui correspond a timeline_start de i+1)
    for i in range(len(subclips) - 1):
        cut_t = subclips[i + 1]['_timeline_start']
        # beat le plus proche
        nearest = min(beats, key=lambda b: abs(b - cut_t))
        offset = nearest - cut_t
        if abs(offset) <= tolerance:
            prev = subclips[i]
            new_out = prev['out_point'] + offset
            min_out = prev['in_point'] + 0.5
            max_out = prev.get('duration', new_out)
            if min_out < new_out < max_out:
                prev['out_point'] = new_out
                # recalcul cumulatif
                t = subclips[0]['_timeline_start']
                for j in range(len(subclips)):
                    subclips[j]['_timeline_start'] = t
                    t += subclips[j]['out_point'] - subclips[j]['in_point']
                snapped += 1
    # nettoie cle interne
    for sc in subclips:
        sc.pop('_timeline_start', None)
    log(f"Beat-sync: {snapped} cut(s) alignes sur beats")
    return subclips


def select_to_target(subclips, target_minutes, log=print):
    if target_minutes <= 0 or not subclips:
        return subclips
    target_sec = target_minutes * 60
    total_avail = sum(sc['out_point'] - sc['in_point'] for sc in subclips)
    if total_avail <= target_sec * 1.05:
        log(f'Duree disponible {total_avail:.1f}s deja proche de la cible {target_sec:.0f}s, on garde tout')
        return subclips
    sorted_by_score = sorted(subclips, key=lambda s: -s.get('score', 0))
    selected = []
    total = 0.0
    for sc in sorted_by_score:
        dur = sc['out_point'] - sc['in_point']
        if total + dur > target_sec * 1.1:
            continue
        selected.append(sc)
        total += dur
        if total >= target_sec * 0.95:
            break
    selected.sort(key=lambda s: (s['parent_index'], s['in_point']))
    log(f'Selection : {len(selected)}/{len(subclips)} sub-clips, {total:.1f}s / {target_sec:.0f}s cible')
    return selected


def apply_trim_analysis(clips, folder, strength, log=print):
    """Calcule in_point/out_point pour chaque clip via analyze_trim + cache. Exclut les clips trop courts."""
    if strength <= 0 or not clips:
        return clips
    cache = _load_trim_cache(folder)
    to_analyze = []
    for c in clips:
        key = _cache_key(c['path'])
        hit = cache.get(key) if key else None
        if hit and hit.get('strength') == strength:
            c['in_point'] = float(hit.get('in_point', 0.0))
            c['out_point'] = float(hit.get('out_point', c['duration']))
            c['trim_reasons'] = list(hit.get('reasons', []))
        else:
            to_analyze.append(c)

    if to_analyze:
        log(f'Auto-trim: analyse {len(to_analyze)} clip(s) (force={strength})...')
        with ThreadPoolExecutor(max_workers=min(4, len(to_analyze))) as ex:
            futures = {ex.submit(analyze_trim, c['path'], c['duration'], strength): c
                       for c in to_analyze}
            for fut in as_completed(futures):
                c = futures[fut]
                try:
                    in_pt, out_pt, reasons = fut.result()
                except Exception as e:
                    log(f'  {c["name"]}: trim failed ({e}), garde duree complete')
                    in_pt, out_pt, reasons = 0.0, c['duration'], []
                c['in_point'] = in_pt
                c['out_point'] = out_pt
                c['trim_reasons'] = reasons
                key = _cache_key(c['path'])
                if key:
                    cache[key] = {'strength': strength, 'in_point': in_pt,
                                  'out_point': out_pt, 'reasons': reasons}
        _save_trim_cache(folder, cache)

    kept = []
    for c in clips:
        if trimmed_duration(c) < 1.0:
            log(f'  exclu: {c["name"]} (duree trimmee < 1s, raisons: {c["trim_reasons"]})')
            continue
        if c['trim_reasons']:
            saved = c['duration'] - trimmed_duration(c)
            log(f'  {c["name"]}: -{saved:.1f}s ({", ".join(c["trim_reasons"])})')
        kept.append(c)
    total_saved = sum(c['duration'] - trimmed_duration(c) for c in kept)
    log(f'Auto-trim: {len(clips) - len(kept)} clip(s) exclu(s), {total_saved:.1f}s economisees au total')
    return kept


def scan_folder(folder, auto_trim=False, trim_strength=30, target_minutes=0,
                music_path=None, beat_sync=False, log=print):
    folder = Path(folder)
    files = [p for p in folder.iterdir() if is_source_video(p)]
    clips = []
    for f in files:
        info = probe_video(f)
        if info and info['width'] > 0:
            clips.append(info)
    clips.sort(key=lambda c: c['creation_time'] or '')
    if auto_trim:
        clips = apply_trim_analysis(clips, folder, trim_strength, log=log)
    if target_minutes > 0 and clips:
        subclips = split_into_subclips(clips, target_minutes, log=log)
        subclips = score_subclips(subclips, folder=folder, log=log)
        clips = select_to_target(subclips, target_minutes, log=log)
    if music_path and beat_sync and clips:
        beats_info = detect_beats(music_path, log=log)
        if beats_info:
            bpm, beats = beats_info
            log(f"Beats: {bpm:.1f} BPM, {len(beats)} marqueurs")
            clips = snap_subclips_to_beats(clips, beats, log=log)
    return clips


def cap_resolution(w, h, max_res):
    caps = {'4k': (3840, 2160), '1080p': (1920, 1080), 'source': (99999, 99999)}
    cap_w, cap_h = caps.get(max_res, (3840, 2160))
    if w > cap_w:
        ratio = h / w if w else 1
        w = cap_w
        h = int(cap_w * ratio)
        if h > cap_h:
            h = cap_h
    if w % 2:
        w -= 1
    if h % 2:
        h -= 1
    return w, h


def encoder_args(encoder, quality):
    if encoder == 'nvenc':
        return 'hevc_nvenc', ['-preset', 'p5', '-tune', 'hq', '-rc', 'vbr',
                              '-cq', str(quality), '-b:v', '0', '-tag:v', 'hvc1']
    if encoder == 'qsv':
        return 'hevc_qsv', ['-preset', 'slow', '-global_quality', str(quality),
                            '-tag:v', 'hvc1']
    if encoder == 'vaapi':
        return 'hevc_vaapi', ['-qp', str(quality), '-tag:v', 'hvc1']
    if encoder == 'x265':
        return 'libx265', ['-preset', 'medium', '-crf', str(quality), '-tag:v', 'hvc1']
    raise ValueError(f"Encoder inconnu: {encoder}")


def build_filter_complex(clips, max_w, max_h, fps, style='neutral', custom_lut=None,
                         with_music=False):
    style_chain = style_filter_ffmpeg(style, custom_lut)
    style_segment = f',{style_chain}' if style_chain else ''
    parts = []
    maps = ''
    for i in range(len(clips)):
        parts.append(
            f"[{i}:v]scale={max_w}:{max_h}:force_original_aspect_ratio=decrease,"
            f"pad={max_w}:{max_h}:(ow-iw)/2:(oh-ih)/2:black,"
            f"setsar=1,fps={fps}{style_segment},format=yuv420p[v{i}];"
        )
        parts.append(
            f"[{i}:a]aresample=48000,aformat=channel_layouts=stereo[a{i}];"
        )
        maps += f"[v{i}][a{i}]"
    if with_music:
        parts.append(f"{maps}concat=n={len(clips)}:v=1:a=1[outv][src_a];")
        music_idx = len(clips)
        parts.append(
            f"[{music_idx}:a]aresample=48000,aformat=channel_layouts=stereo,volume=0.4[mus_a];"
        )
        parts.append("[src_a][mus_a]amix=inputs=2:duration=first:dropout_transition=0[outa]")
    else:
        parts.append(f"{maps}concat=n={len(clips)}:v=1:a=1[outv][outa]")
    return ''.join(parts)


def build_preview_cmd(clips, output, encoder, max_w, max_h, fps,
                      style='neutral', custom_lut=None, samples=12, sample_dur=1.0):
    """Construit la cmd ffmpeg pour un preview court (~12s) compose d'extraits 1s."""
    if not clips:
        return None
    # Echantillonnage uniforme dans la liste
    n = min(samples, len(clips))
    if len(clips) <= n:
        picked = list(clips)
    else:
        step = len(clips) / n
        picked = [clips[int(i * step)] for i in range(n)]
    # Cap preview a 720p pour vitesse
    pw = min(max_w, 1280)
    ph = min(max_h, 720)
    if pw % 2:
        pw -= 1
    if ph % 2:
        ph -= 1

    style_chain = style_filter_ffmpeg(style, custom_lut)
    style_segment = f',{style_chain}' if style_chain else ''
    enc_name = 'hevc_nvenc' if encoder == 'nvenc' else 'libx265'
    enc_args = (['-preset', 'p1', '-tune', 'll', '-cq', '30', '-b:v', '0', '-tag:v', 'hvc1']
                if encoder == 'nvenc'
                else ['-preset', 'ultrafast', '-crf', '28', '-tag:v', 'hvc1'])

    parts = []
    maps = ''
    cmd = ['ffmpeg', '-hide_banner', '-y']
    for i, c in enumerate(picked):
        in_pt = c.get('in_point', 0.0)
        out_pt = c.get('out_point', c['duration'])
        mid = (in_pt + out_pt) / 2
        seg_dur = min(sample_dur, out_pt - in_pt)
        seg_start = max(in_pt, mid - seg_dur / 2)
        cmd += ['-ss', f'{seg_start:.3f}', '-t', f'{seg_dur:.3f}', '-i', c['path']]
        parts.append(
            f"[{i}:v]scale={pw}:{ph}:force_original_aspect_ratio=decrease,"
            f"pad={pw}:{ph}:(ow-iw)/2:(oh-ih)/2:black,"
            f"setsar=1,fps={fps}{style_segment},format=yuv420p[v{i}];"
        )
        parts.append(
            f"[{i}:a]aresample=48000,aformat=channel_layouts=stereo[a{i}];"
        )
        maps += f"[v{i}][a{i}]"
    parts.append(f"{maps}concat=n={len(picked)}:v=1:a=1[outv][outa]")
    filter_complex = ''.join(parts)
    cmd += ['-filter_complex', filter_complex,
            '-map', '[outv]', '-map', '[outa]',
            '-c:v', enc_name] + enc_args + [
        '-c:a', 'aac', '-b:a', '96k',
        '-movflags', '+faststart',
        str(output),
    ]
    return cmd


def build_ffmpeg_cmd(clips, output, encoder, quality, max_w, max_h, fps,
                     style='neutral', custom_lut=None, music_path=None):
    enc_name, enc_args = encoder_args(encoder, quality)
    with_music = bool(music_path)
    filter_complex = build_filter_complex(clips, max_w, max_h, fps, style, custom_lut,
                                          with_music=with_music)

    cmd = ['ffmpeg', '-hide_banner', '-y']
    for c in clips:
        in_pt = c.get('in_point', 0.0)
        out_pt = c.get('out_point', c['duration'])
        if in_pt > 0.0:
            cmd += ['-ss', f'{in_pt:.3f}']
        if out_pt < c['duration'] - 0.001:
            cmd += ['-to', f'{out_pt:.3f}']
        cmd += ['-i', c['path']]
    if with_music:
        cmd += ['-stream_loop', '-1', '-i', str(music_path)]
    cmd += ['-filter_complex', filter_complex,
            '-map', '[outv]', '-map', '[outa]',
            '-c:v', enc_name] + enc_args + [
        '-c:a', 'aac', '-b:a', '192k',
        '-movflags', '+faststart',
        str(output),
    ]
    return cmd


def sec_to_tc(seconds):
    seconds = max(0.0, float(seconds))
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = seconds - h * 3600 - m * 60
    return f"{h:02d}:{m:02d}:{s:06.3f}"


FADE_SEC = 0.7


def parse_iso_time(s):
    if not s:
        return None
    try:
        return datetime.datetime.fromisoformat(s.replace('Z', '+00:00'))
    except (ValueError, TypeError):
        return None


def compute_break_indices(clips, gap_minutes):
    """Return set of clip indices AFTER which to insert a black transition.
    Le gap est calcule sur les bornes effectives (in/out_point), pas la duree brute."""
    if gap_minutes <= 0 or len(clips) < 2:
        return set()
    threshold = gap_minutes * 60
    breaks = set()
    for i in range(len(clips) - 1):
        t_i = parse_iso_time(clips[i].get('creation_time'))
        t_next = parse_iso_time(clips[i + 1].get('creation_time'))
        if t_i is None or t_next is None:
            continue
        end_i = t_i + datetime.timedelta(seconds=clips[i].get('out_point', clips[i]['duration']))
        start_next = t_next + datetime.timedelta(seconds=clips[i + 1].get('in_point', 0.0))
        if (start_next - end_i).total_seconds() > threshold:
            breaks.add(i)
    return breaks


