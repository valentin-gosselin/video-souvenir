        def eventFilter(self, obj, event):
            if obj is self.clip_list and event.type() == event.Type.KeyPress:
                if event.key() == Qt.Key_Delete:
                    for item in self.clip_list.selectedItems():
                        self.clip_list.takeItem(self.clip_list.row(item))
                    return True
            return super().eventFilter(obj, event)

        def browse_folder(self):
            start = self.folder_edit.text() or str(Path.home())
            d = QFileDialog.getExistingDirectory(self, "Choisis le dossier source", start)
            if d:
                self.folder_edit.setText(d)
                self.scan()

        def scan(self):
            folder = self.folder_edit.text().strip()
            if not folder or not Path(folder).is_dir():
                QMessageBox.warning(self, "Dossier invalide", "Choisis d'abord un dossier valide.")
                return
            self.clip_list.clear()
            self.clips = []
            self.log.append(f"--- Scan de {folder} ---")
            self.scan_thread = ScanThread(folder)
            self.scan_thread.clip_found.connect(self.on_clip_found)
            self.scan_thread.finished_scan.connect(self.on_scan_done)
            self.scan_thread.error.connect(lambda e: self.log.append(f"Erreur scan: {e}"))
            self.scan_thread.start()

        def on_clip_found(self, info):
            self.clips.append(info)
            self.clips.sort(key=lambda c: c.get('creation_time') or '')
            self.clip_list.clear()
            for c in self.clips:
                m, s = divmod(int(c['duration']), 60)
                label = f"{c['name']}    {c['width']}x{c['height']}    {m}m{s:02d}s"
                item = QListWidgetItem(label)
                item.setData(Qt.UserRole, c['path'])
                self.clip_list.addItem(item)

        def on_scan_done(self, ok, ko):
            msg = f"--- {ok} clips lisibles"
            if ko:
                msg += f", {ko} illisibles (probablement en cours de sync ou corrompus)"
            msg += " ---"
            self.log.append(msg)
            if ok == 0 and ko > 0:
                QMessageBox.warning(
                    self, "Aucun clip lisible",
                    f"{ko} fichiers detectes mais ffprobe a echoue sur tous.\n\n"
                    "Causes possibles : ffmpeg-free (decodeur H.264 casse), fichiers en cours\n"
                    "de sync Nextcloud, ou format non supporte."
                )

        def get_ordered_clips(self):
            ordered = []
            for i in range(self.clip_list.count()):
                path = self.clip_list.item(i).data(Qt.UserRole)
                clip = next((c for c in self.clips if c['path'] == path), None)
                if clip:
                    ordered.append(clip)
            return ordered

        def launch(self):
            clips = self.get_ordered_clips()
            if not clips:
                QMessageBox.warning(self, "Pas de clips", "Selectionne des clips d'abord.")
                return

            mode_map = {0: 'render', 1: 'kdenlive', 2: 'both'}
            mode = mode_map[self.mode_combo.currentIndex()]

            encoder_map = {0: 'auto', 1: 'nvenc', 2: 'qsv', 3: 'vaapi', 4: 'x265'}
            encoder = encoder_map[self.enc_combo.currentIndex()]
            if encoder == 'auto':
                encoder = detect_encoder()
                if not encoder:
                    QMessageBox.critical(self, "Erreur", "Aucun encoder HEVC disponible.")
                    return

            res_map = {0: '4k', 1: '1080p', 2: 'source'}
            max_res = res_map[self.res_combo.currentIndex()]
            fps = int(self.fps_combo.currentText())
            quality = self.quality_spin.value()

            out = self.output_edit.text().strip()
            if not out:
                folder = Path(clips[0]['path']).parent
                out = str(folder / f"souvenir-{datetime.datetime.now():%Y%m%d-%H%M%S}.mp4")

            max_w = max(c['width'] for c in clips)
            max_h = max(c['height'] for c in clips)
            max_w, max_h = cap_resolution(max_w, max_h, max_res)

            cmd = None
            kdenlive_args = None
            if mode in ('kdenlive', 'both'):
                kdenlive_path = Path(out).with_suffix('.kdenlive')
                kdenlive_args = (clips, kdenlive_path, max_w, max_h, fps)
            if mode in ('render', 'both'):
                cmd = build_ffmpeg_cmd(clips, out, encoder, quality, max_w, max_h, fps)

            self.launch_btn.setEnabled(False)
            self.progress.setVisible(True)
            self.progress.setRange(0, 100)
            self.progress.setValue(0)
            self.log.append(
                f"--- Lancement (mode={mode}, encoder={encoder}, {max_w}x{max_h}@{fps}fps, q={quality}) ---"
            )

            total_dur = sum(c['duration'] for c in clips)
            self.encode_thread = EncodeThread(cmd, kdenlive_args, total_dur)
            self.encode_thread.log_line.connect(self.log.append)
            self.encode_thread.progress_pct.connect(self.progress.setValue)
            self.encode_thread.done.connect(self.on_encode_done)
            self.encode_thread.start()

        def on_encode_done(self, code):
            self.progress.setVisible(False)
            self.launch_btn.setEnabled(True)
            if code == 0:
                self.log.append("--- Termine avec succes ---")
                QMessageBox.information(self, "Termine", "Encodage / projet termine !")
            else:
                self.log.append(f"--- Echec (code {code}) ---")
                QMessageBox.warning(self, "Erreur",
                                    f"L'encodage a echoue (code {code}). Voir le log.")

    app = QApplication(sys.argv)
    app.setApplicationName("Video Souvenir")
    app.setDesktopFileName("video-souvenir")
    win = MainWindow()
    win.show()
    return app.exec()


def main():
    parser = argparse.ArgumentParser(
        description="Assemble des clips video en montage HEVC ou projet Kdenlive."
    )
    parser.add_argument('folder', nargs='?', help="Dossier source. Si omis, ouvre l'UI.")
    parser.add_argument('output', nargs='?', help="Fichier de sortie (auto si omis).")
    parser.add_argument('--mode', choices=['render', 'kdenlive', 'both'], default='render')
    parser.add_argument('--encoder', default='auto',
                        choices=['auto', 'nvenc', 'qsv', 'vaapi', 'x265'])
    parser.add_argument('--quality', type=int, default=24)
    parser.add_argument('--fps', type=int, default=30)
    parser.add_argument('--max-res', dest='max_res', default='4k',
                        choices=['4k', '1080p', 'source'])
    args = parser.parse_args()

    if not args.folder:
        return run_ui()
    return run_cli(args)


if __name__ == '__main__':
    sys.exit(main())
