        from PySide6.QtGui import QFont
        from PySide6.QtWidgets import (
            QApplication, QComboBox, QFileDialog, QGridLayout, QGroupBox,
            QHBoxLayout, QLabel, QLineEdit, QListWidget, QListWidgetItem,
            QMainWindow, QMessageBox, QProgressBar, QPushButton, QSpinBox,
            QTextEdit, QVBoxLayout, QWidget,
        )
    except ImportError:
        print("PySide6 manque. Installe avec:", file=sys.stderr)
        print("  /home/goss/miniconda3/bin/pip install PySide6", file=sys.stderr)
        return 1

    class ScanThread(QThread):
        clip_found = Signal(dict)
        finished_scan = Signal(int, int)
        error = Signal(str)

        def __init__(self, folder):
            super().__init__()
            self.folder = folder

        def run(self):
            try:
                folder = Path(self.folder)
                files = sorted([p for p in folder.iterdir() if is_source_video(p)])
                ok = 0
                ko = 0
                for f in files:
                    info = probe_video(f)
                    if info and info['width'] > 0:
                        self.clip_found.emit(info)
                        ok += 1
                    else:
                        ko += 1
                self.finished_scan.emit(ok, ko)
            except Exception as e:
                self.error.emit(str(e))

    class EncodeThread(QThread):
        log_line = Signal(str)
        progress_pct = Signal(int)
        done = Signal(int)

        def __init__(self, cmd, kdenlive_args, total_duration):
            super().__init__()
            self.cmd = cmd
            self.kdenlive_args = kdenlive_args
            self.total_duration = total_duration

        def run(self):
            if self.kdenlive_args:
                try:
                    generate_kdenlive(*self.kdenlive_args)
                    self.log_line.emit(f"Projet Kdenlive genere: {self.kdenlive_args[1]}")
                except Exception as e:
                    self.log_line.emit(f"Erreur Kdenlive: {e}")

            if self.cmd is None:
                self.done.emit(0)
                return

            self.log_line.emit("Commande: " + ' '.join(repr(a) if ' ' in a else a for a in self.cmd))
            try:
                proc = subprocess.Popen(self.cmd, stdout=subprocess.PIPE,
                                        stderr=subprocess.STDOUT, text=True,
                                        bufsize=1)
                time_re = re.compile(r'time=(\d+):(\d+):(\d+\.\d+)')
                for line in proc.stdout:
                    line = line.rstrip()
                    m = time_re.search(line)
                    if m and self.total_duration > 0:
                        h, mn, s = m.groups()
                        elapsed = int(h) * 3600 + int(mn) * 60 + float(s)
                        pct = min(100, int(elapsed / self.total_duration * 100))
                        self.progress_pct.emit(pct)
                    self.log_line.emit(line)
                proc.wait()
                self.done.emit(proc.returncode)
            except Exception as e:
                self.log_line.emit(f"Erreur: {e}")
                self.done.emit(1)

