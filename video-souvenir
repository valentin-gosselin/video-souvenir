#!/usr/bin/env python3
"""
video-souvenir - Assemble des clips video en un montage HEVC ou projet Kdenlive.

Usage:
  video-souvenir                          # ouvre l'UI PySide6
  video-souvenir <dossier> [sortie]       # mode CLI
"""

import argparse
import datetime
import html
import json
import re
import subprocess
import sys
from pathlib import Path

VIDEO_EXTS = {'.mp4', '.mov', '.mts', '.m2ts', '.avi', '.mkv'}

# Fichiers auto-generes par ce script - a exclure du scan
GENERATED_RE = re.compile(r'^souvenir-\d{8}-\d{6}\.(mp4|kdenlive)$', re.IGNORECASE)


def detect_encoder():
    try:
        result = subprocess.run(['ffmpeg', '-hide_banner', '-encoders'],
                                capture_output=True, text=True, timeout=10)
        encoders = result.stdout
    except Exception:
        return None

    try:
        subprocess.run(['nvidia-smi', '-L'], capture_output=True, check=True, timeout=5)
        if 'hevc_nvenc' in encoders:
            return 'nvenc'
    except Exception:
        pass

    has_dri = Path('/dev/dri/renderD128').exists()
    if has_dri and 'hevc_qsv' in encoders:
        return 'qsv'
    if has_dri and 'hevc_vaapi' in encoders:
        return 'vaapi'
    if 'libx265' in encoders:
        return 'x265'
    return None


def probe_video(path):
    try:
        cmd = ['ffprobe', '-v', 'error', '-print_format', 'json',
               '-show_format', '-show_streams', str(path)]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0 or not result.stdout.strip():
            return None
        data = json.loads(result.stdout)
    except Exception:
        return None

    info = {'path': str(path), 'name': Path(path).name,
            'width': 0, 'height': 0, 'duration': 0.0, 'creation_time': None}

    fmt = data.get('format', {})
    try:
        info['duration'] = float(fmt.get('duration', 0) or 0)
    except (TypeError, ValueError):
        pass

    tags = fmt.get('tags', {}) or {}
    info['creation_time'] = tags.get('creation_time')

    for s in data.get('streams', []):
        if s.get('codec_type') == 'video':
            info['width'] = s.get('width', 0) or 0
            info['height'] = s.get('height', 0) or 0
            break

    if not info['creation_time']:
        mtime = datetime.datetime.fromtimestamp(Path(path).stat().st_mtime)
        info['creation_time'] = mtime.isoformat()

    return info


def is_source_video(path):
    p = Path(path)
    return (p.is_file()
            and p.suffix.lower() in VIDEO_EXTS
            and not GENERATED_RE.match(p.name))


def scan_folder(folder):
    folder = Path(folder)
    files = [p for p in folder.iterdir() if is_source_video(p)]
    clips = []
    for f in files:
        info = probe_video(f)
        if info and info['width'] > 0:
            clips.append(info)
    clips.sort(key=lambda c: c['creation_time'] or '')
    return clips


def cap_resolution(w, h, max_res):
    caps = {'4k': (3840, 2160), '1080p': (1920, 1080), 'source': (99999, 99999)}
    cap_w, cap_h = caps.get(max_res, (3840, 2160))
    if w > cap_w:
        ratio = h / w if w else 1
        w = cap_w
        h = int(cap_w * ratio)
        if h > cap_h:
            h = cap_h
    if w % 2:
        w -= 1
    if h % 2:
        h -= 1
    return w, h


def encoder_args(encoder, quality):
    if encoder == 'nvenc':
        return 'hevc_nvenc', ['-preset', 'p5', '-tune', 'hq', '-rc', 'vbr',
                              '-cq', str(quality), '-b:v', '0', '-tag:v', 'hvc1']
    if encoder == 'qsv':
        return 'hevc_qsv', ['-preset', 'slow', '-global_quality', str(quality),
                            '-tag:v', 'hvc1']
    if encoder == 'vaapi':
        return 'hevc_vaapi', ['-qp', str(quality), '-tag:v', 'hvc1']
    if encoder == 'x265':
        return 'libx265', ['-preset', 'medium', '-crf', str(quality), '-tag:v', 'hvc1']
    raise ValueError(f"Encoder inconnu: {encoder}")


def build_filter_complex(clips, max_w, max_h, fps):
    parts = []
    maps = ''
    for i in range(len(clips)):
        parts.append(
            f"[{i}:v]scale={max_w}:{max_h}:force_original_aspect_ratio=decrease,"
            f"pad={max_w}:{max_h}:(ow-iw)/2:(oh-ih)/2:black,"
            f"setsar=1,fps={fps},format=yuv420p[v{i}];"
        )
        parts.append(
            f"[{i}:a]aresample=48000,aformat=channel_layouts=stereo[a{i}];"
        )
        maps += f"[v{i}][a{i}]"
    parts.append(f"{maps}concat=n={len(clips)}:v=1:a=1[outv][outa]")
    return ''.join(parts)


def build_ffmpeg_cmd(clips, output, encoder, quality, max_w, max_h, fps):
    enc_name, enc_args = encoder_args(encoder, quality)
    filter_complex = build_filter_complex(clips, max_w, max_h, fps)

    cmd = ['ffmpeg', '-hide_banner', '-y']
    for c in clips:
        cmd += ['-i', c['path']]
    cmd += ['-filter_complex', filter_complex,
            '-map', '[outv]', '-map', '[outa]',
            '-c:v', enc_name] + enc_args + [
        '-c:a', 'aac', '-b:a', '192k',
        '-movflags', '+faststart',
        str(output),
    ]
    return cmd


def sec_to_tc(seconds):
    seconds = max(0.0, float(seconds))
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = seconds - h * 3600 - m * 60
    return f"{h:02d}:{m:02d}:{s:06.3f}"


def generate_kdenlive(clips, output_path, max_w, max_h, fps):
    output_path = Path(output_path)
    root_dir = str(output_path.parent.resolve())
    total_sec = sum(c['duration'] for c in clips)
    total_tc = sec_to_tc(total_sec)
    doc_id = str(int(datetime.datetime.now().timestamp() * 1000))

    def esc(s):
        return html.escape(str(s), quote=True)

    L = []
    L.append('<?xml version="1.0" encoding="utf-8"?>')
    L.append(f'<mlt LC_NUMERIC="C" version="7.30.0" producer="main_bin" root="{esc(root_dir)}">')
    L.append(f'  <profile description="custom {max_w}x{max_h} {fps}fps" '
             f'width="{max_w}" height="{max_h}" progressive="1" '
             f'sample_aspect_num="1" sample_aspect_den="1" '
             f'display_aspect_num="16" display_aspect_den="9" '
             f'frame_rate_num="{fps}" frame_rate_den="1" colorspace="709"/>')

    L.append('  <producer id="black_track" in="00:00:00.000" out="23:59:59.000">')
    L.append('    <property name="length">2147483647</property>')
    L.append('    <property name="eof">continue</property>')
    L.append('    <property name="resource">0</property>')
    L.append('    <property name="aspect_ratio">1</property>')
    L.append('    <property name="mlt_service">color</property>')
    L.append('    <property name="set.test_audio">0</property>')
    L.append('    <property name="set.test_image">1</property>')
    L.append('  </producer>')

    for i, c in enumerate(clips):
        dur_tc = sec_to_tc(c['duration'])
        L.append(f'  <producer id="producer{i}" in="00:00:00.000" out="{dur_tc}">')
        L.append(f'    <property name="length">{dur_tc}</property>')
        L.append(f'    <property name="resource">{esc(c["path"])}</property>')
        L.append('    <property name="mlt_service">avformat-novalidate</property>')
        L.append('    <property name="audio_index">1</property>')
        L.append('    <property name="video_index">0</property>')
        L.append(f'    <property name="kdenlive:clipname">{esc(c["name"])}</property>')
        L.append(f'    <property name="kdenlive:id">{i + 2}</property>')
        L.append('  </producer>')

    L.append('  <playlist id="main_bin">')
    L.append(f'    <property name="kdenlive:docproperties.documentid">{doc_id}</property>')
    L.append('    <property name="kdenlive:docproperties.kdenliveversion">24.05.2</property>')
    L.append('    <property name="kdenlive:docproperties.version">1.1</property>')
    L.append('    <property name="xml_retain">1</property>')
    for i, c in enumerate(clips):
        dur_tc = sec_to_tc(c['duration'])
        L.append(f'    <entry producer="producer{i}" in="00:00:00.000" out="{dur_tc}"/>')
    L.append('  </playlist>')

    L.append('  <playlist id="playlist0">')
    L.append('    <property name="kdenlive:audio_track">0</property>')
    for i, c in enumerate(clips):
        dur_tc = sec_to_tc(c['duration'])
        L.append(f'    <entry producer="producer{i}" in="00:00:00.000" out="{dur_tc}"/>')
    L.append('  </playlist>')
    L.append('  <playlist id="playlist1">')
    L.append('    <property name="kdenlive:audio_track">0</property>')
    L.append('  </playlist>')

    L.append(f'  <tractor id="tractor0" in="00:00:00.000" out="{total_tc}">')
    L.append('    <property name="kdenlive:audio_track">0</property>')
    L.append('    <property name="kdenlive:trackheight">100</property>')
    L.append('    <property name="kdenlive:timeline_active">1</property>')
    L.append('    <property name="kdenlive:track_name">V1</property>')
    L.append('    <track producer="playlist0"/>')
    L.append('    <track producer="playlist1"/>')
    L.append('  </tractor>')

    L.append(f'  <tractor id="maintractor" in="00:00:00.000" out="{total_tc}">')
    L.append('    <track producer="black_track"/>')
    L.append('    <track producer="tractor0"/>')
    L.append('  </tractor>')

    L.append('</mlt>')

    output_path.write_text('\n'.join(L), encoding='utf-8')


def run_cli(args):
    folder = Path(args.folder)
    if not folder.is_dir():
        print(f"Erreur: '{folder}' n'est pas un dossier", file=sys.stderr)
        return 1

    print(f"Scan de {folder}...")
    clips = scan_folder(folder)
    if not clips:
        print("Aucune video lisible trouvee (ffprobe a echoue sur tous les fichiers).",
              file=sys.stderr)
        print("Si tu vois des erreurs 'libopenh264', swap ffmpeg-free vers ffmpeg:",
              file=sys.stderr)
        print("  sudo dnf swap ffmpeg-free ffmpeg --allowerasing", file=sys.stderr)
        return 1

    print(f"{len(clips)} clips trouves (ordre chronologique):")
    for c in clips:
        print(f"  - {c['name']}  ({c['width']}x{c['height']}, {c['duration']:.1f}s)")

    encoder = args.encoder
    if encoder == 'auto':
        encoder = detect_encoder()
        if not encoder:
            print("Aucun encoder HEVC disponible", file=sys.stderr)
            return 1
    print(f"Encoder: {encoder}")

    out_base = args.output or str(folder / f"souvenir-{datetime.datetime.now():%Y%m%d-%H%M%S}.mp4")

    max_w = max(c['width'] for c in clips)
    max_h = max(c['height'] for c in clips)
    max_w, max_h = cap_resolution(max_w, max_h, args.max_res)

    if args.mode in ('kdenlive', 'both'):
        kdenlive_path = Path(out_base).with_suffix('.kdenlive')
        print(f"Generation projet Kdenlive: {kdenlive_path}")
        generate_kdenlive(clips, kdenlive_path, max_w, max_h, args.fps)

    if args.mode in ('render', 'both'):
        print(f"Encodage: {out_base}")
        cmd = build_ffmpeg_cmd(clips, out_base, encoder, args.quality, max_w, max_h, args.fps)
        result = subprocess.run(cmd)
        if result.returncode != 0:
            return result.returncode
        print(f"Termine: {out_base}")

    return 0


def run_ui():
