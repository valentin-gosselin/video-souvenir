            d = QFileDialog.getExistingDirectory(self, "Choisis le dossier source", start)
            if d:
                self.folder_edit.setText(d)
                self.scan()

        def scan(self):
            folder = self.folder_edit.text().strip()
            if not folder or not Path(folder).is_dir():
                QMessageBox.warning(self, "Dossier invalide", "Choisis d'abord un dossier valide.")
                return
            self.clip_list.clear()
            self.clips = []
            self.log.append(f"--- Scan de {folder} ---")
            auto_trim = self.trim_check.isChecked()
            strength = self.trim_strength_spin.value() if auto_trim else 0
            # Auto-detect d'une LUT dans le dossier
            auto_lut = detect_folder_lut(folder)
            if auto_lut and not self.lut_edit.text():
                self.lut_edit.setText(auto_lut)
                self.log.append(f"LUT auto-detectee : {auto_lut}")
                # passe sur custom si l'utilisateur n'a pas force un preset
                if self.style_combo.currentIndex() == 0:  # neutral
                    for i, (key, _) in enumerate(STYLE_LABELS):
                        if key == 'custom':
                            self.style_combo.setCurrentIndex(i)
                            break
            target = self.target_spin.value()
            music_path = self.music_edit.text().strip() or None
            beat_sync = self.beatsync_check.isChecked()
            self.scan_thread = ScanThread(folder, auto_trim=auto_trim, trim_strength=strength,
                                          target_minutes=target, music_path=music_path,
                                          beat_sync=beat_sync)
            self.scan_thread.clip_found.connect(self.on_clip_found)
            self.scan_thread.finished_scan.connect(self.on_scan_done)
            self.scan_thread.log_line.connect(self.log.append)
            self.scan_thread.error.connect(lambda e: self.log.append(f"Erreur scan: {e}"))
            self.scan_thread.start()

        def on_clip_found(self, info):
            # Assigne un id unique pour permettre les sub-clips multiples du meme path
            info['_uid'] = f"{info['path']}|{info.get('in_point', 0.0):.3f}|{info.get('out_point', 0.0):.3f}"
            self.clips.append(info)
            self.clips.sort(key=lambda c: (c.get('creation_time') or '', c.get('in_point', 0.0)))
            self.clip_list.clear()
            # detection cas sub-clipping pour ajouter un suffixe utile
            path_counts = {}
            for c in self.clips:
                path_counts[c['path']] = path_counts.get(c['path'], 0) + 1
            seen_per_path = {}
            for c in self.clips:
                td = trimmed_duration(c)
                m, s = divmod(int(td), 60)
                label = f"{c['name']}    {c['width']}x{c['height']}    {m}m{s:02d}s"
                if path_counts[c['path']] > 1:
                    seen_per_path[c['path']] = seen_per_path.get(c['path'], 0) + 1
                    label += f"  [#{seen_per_path[c['path']]} {c['in_point']:.1f}-{c['out_point']:.1f}s]"
                elif td < c['duration'] - 0.05:
                    om, os_ = divmod(int(c['duration']), 60)
                    label += f"  (orig {om}m{os_:02d}s)"
                item = QListWidgetItem(label)
                item.setData(Qt.UserRole, c['_uid'])
                self.clip_list.addItem(item)

        def on_scan_done(self, ok, ko):
            msg = f"--- {ok} clips lisibles"
            if ko:
                msg += f", {ko} illisibles (probablement en cours de sync ou corrompus)"
            msg += " ---"
            self.log.append(msg)
            if ok == 0 and ko > 0:
                QMessageBox.warning(
                    self, "Aucun clip lisible",
                    f"{ko} fichiers detectes mais ffprobe a echoue sur tous.\n\n"
                    "Causes possibles : ffmpeg-free (decodeur H.264 casse), fichiers en cours\n"
                    "de sync Nextcloud, ou format non supporte."
                )

        def get_ordered_clips(self):
            ordered = []
            for i in range(self.clip_list.count()):
                uid = self.clip_list.item(i).data(Qt.UserRole)
                clip = next((c for c in self.clips if c.get('_uid') == uid), None)
                if clip:
                    ordered.append(clip)
            return ordered

        def launch(self, preview=False):
            clips = self.get_ordered_clips()
            if not clips:
                QMessageBox.warning(self, "Pas de clips", "Selectionne des clips d'abord.")
                return

            mode_map = {0: 'render', 1: 'kdenlive', 2: 'both'}
            mode = mode_map[self.mode_combo.currentIndex()]

            encoder_map = {0: 'auto', 1: 'nvenc', 2: 'qsv', 3: 'vaapi', 4: 'x265'}
            encoder = encoder_map[self.enc_combo.currentIndex()]
            if encoder == 'auto':
                encoder = detect_encoder()
                if not encoder:
                    QMessageBox.critical(self, "Erreur", "Aucun encoder HEVC disponible.")
                    return

            res_map = {0: '4k', 1: '1080p', 2: 'source'}
            max_res = res_map[self.res_combo.currentIndex()]
            fps = int(self.fps_combo.currentText())
            quality = self.quality_spin.value()

            out = self.output_edit.text().strip()
            if not out:
                folder = Path(clips[0]['path']).parent
                out = str(folder / f"souvenir-{datetime.datetime.now():%Y%m%d-%H%M%S}.mp4")

            max_w = max(c['width'] for c in clips)
            max_h = max(c['height'] for c in clips)
            max_w, max_h = cap_resolution(max_w, max_h, max_res)

            style_key = STYLE_LABELS[self.style_combo.currentIndex()][0]
            custom_lut = self.lut_edit.text().strip() or None
            if style_key == 'custom' and not custom_lut:
                QMessageBox.warning(self, "LUT manquante",
                                    "Style 'Custom LUT...' choisi mais aucun fichier .cube indique.")
                return

            music_path = self.music_edit.text().strip() or None
            self._preview_output = None
            cmd = None
            kdenlive_args = None
            if preview:
                preview_path = str(Path(out).with_name(Path(out).stem + '-preview.mp4'))
                cmd = build_preview_cmd(clips, preview_path, encoder, max_w, max_h, fps,
                                        style=style_key, custom_lut=custom_lut)
                self._preview_output = preview_path
                self.log.append(f"--- Preview (style={style_key}) -> {preview_path} ---")
                total_dur = min(12.0, len(clips) * 1.0)
            else:
                if mode in ('kdenlive', 'both'):
                    kdenlive_path = Path(out).with_suffix('.kdenlive')
                    kdenlive_args = (clips, kdenlive_path, max_w, max_h, fps,
                                     self.gap_spin.value(), style_key, custom_lut,
                                     music_path)
                if mode in ('render', 'both'):
                    cmd = build_ffmpeg_cmd(clips, out, encoder, quality, max_w, max_h, fps,
                                           style=style_key, custom_lut=custom_lut,
                                           music_path=music_path)
                self.log.append(
                    f"--- Lancement (mode={mode}, encoder={encoder}, {max_w}x{max_h}@{fps}fps, q={quality}, style={style_key}) ---"
                )
                total_dur = sum(trimmed_duration(c) for c in clips)

            self.launch_btn.setEnabled(False)
            self.preview_btn.setEnabled(False)
            self.progress.setVisible(True)
            self.progress.setRange(0, 100)
            self.progress.setValue(0)

            self.encode_thread = EncodeThread(cmd, kdenlive_args, total_dur)
            self.encode_thread.log_line.connect(self.log.append)
            self.encode_thread.progress_pct.connect(self.progress.setValue)
            self.encode_thread.done.connect(self.on_encode_done)
            self.encode_thread.start()

        def on_encode_done(self, code):
            self.progress.setVisible(False)
            self.launch_btn.setEnabled(True)
            self.preview_btn.setEnabled(True)
            if code == 0:
                self.log.append("--- Termine avec succes ---")
                if self._preview_output:
                    try:
                        from PySide6.QtCore import QUrl
                        from PySide6.QtGui import QDesktopServices
                        QDesktopServices.openUrl(QUrl.fromLocalFile(self._preview_output))
                    except Exception as e:
                        self.log.append(f"(Ouverture preview echouee: {e})")
                else:
                    QMessageBox.information(self, "Termine", "Encodage / projet termine !")
            else:
                self.log.append(f"--- Echec (code {code}) ---")
                QMessageBox.warning(self, "Erreur",
                                    f"L'encodage a echoue (code {code}). Voir le log.")

    app = QApplication(sys.argv)
    app.setApplicationName("Video Souvenir")
    app.setDesktopFileName("video-souvenir")
    win = MainWindow()
    win.show()
    return app.exec()


def main():
    parser = argparse.ArgumentParser(
        description="Assemble des clips video en montage HEVC ou projet Kdenlive."
    )
    parser.add_argument('folder', nargs='?', help="Dossier source. Si omis, ouvre l'UI.")
    parser.add_argument('output', nargs='?', help="Fichier de sortie (auto si omis).")
    parser.add_argument('--mode', choices=['render', 'kdenlive', 'both'], default='render')
    parser.add_argument('--encoder', default='auto',
                        choices=['auto', 'nvenc', 'qsv', 'vaapi', 'x265'])
    parser.add_argument('--quality', type=int, default=24)
    parser.add_argument('--fps', type=int, default=30)
    parser.add_argument('--max-res', dest='max_res', default='4k',
                        choices=['4k', '1080p', 'source'])
    parser.add_argument('--gap-minutes', dest='gap_minutes', type=int, default=20,
                        help="Seuil (min) au-dela duquel on insere un noir entre clips (Kdenlive). 0 = desactive.")
    parser.add_argument('--auto-trim', dest='auto_trim', action='store_true', default=True,
                        help="Active l'auto-trim par clip (silence/noir/flou en debut/fin). Defaut: active.")
    parser.add_argument('--no-auto-trim', dest='auto_trim', action='store_false',
                        help="Desactive l'auto-trim.")
    parser.add_argument('--trim-strength', dest='trim_strength', type=int, default=30,
                        help="Agressivite auto-trim 0-100 (0=off, 30=conservateur, 100=agressif).")
    parser.add_argument('--style', default='neutral',
                        choices=[k for k, _ in STYLE_LABELS],
                        help="Style colorimetrique applique sur V1. 'custom' utilise --lut.")
    parser.add_argument('--lut', dest='custom_lut', default=None,
                        help="Chemin vers un fichier .cube (force style=custom). "
                             "Sinon, auto-detect d'un .cube dans le dossier source.")
    parser.add_argument('--target-duration', dest='target_minutes', type=int, default=0,
                        help="Duree cible en minutes (0=desactive). Si >0, decoupe les clips "
                             "longs en sub-clips, score, garde les meilleurs pour atteindre la cible.")
    parser.add_argument('--preview', action='store_true',
                        help="Genere un preview MP4 court (~12s) au lieu du montage complet.")
    parser.add_argument('--music', dest='music_path', default=None,
                        help="Fichier audio (MP3/WAV/...) ajoute en piste A2 dans le projet Kdenlive.")
    parser.add_argument('--beat-sync', dest='beat_sync', action='store_true',
                        help="Si --music fourni, aligne les cuts sur les beats detectes (librosa).")
    args = parser.parse_args()

    if not args.folder:
        return run_ui()
    return run_cli(args)


if __name__ == '__main__':
    sys.exit(main())
