    class ScanThread(QThread):
        clip_found = Signal(dict)
        finished_scan = Signal(int, int)
        log_line = Signal(str)
        error = Signal(str)

        def __init__(self, folder, auto_trim=False, trim_strength=30, target_minutes=0,
                     music_path=None, beat_sync=False):
            super().__init__()
            self.folder = folder
            self.auto_trim = auto_trim
            self.trim_strength = trim_strength
            self.target_minutes = target_minutes
            self.music_path = music_path
            self.beat_sync = beat_sync

        def run(self):
            try:
                folder = Path(self.folder)
                files = sorted([p for p in folder.iterdir() if is_source_video(p)])
                probed = []
                ko = 0
                for f in files:
                    info = probe_video(f)
                    if info and info['width'] > 0:
                        probed.append(info)
                    else:
                        ko += 1
                probed.sort(key=lambda c: c['creation_time'] or '')
                if self.auto_trim and self.trim_strength > 0 and probed:
                    probed = apply_trim_analysis(
                        probed, folder, self.trim_strength, log=self.log_line.emit)
                if self.target_minutes > 0 and probed:
                    subclips = split_into_subclips(probed, self.target_minutes,
                                                   log=self.log_line.emit)
                    subclips = score_subclips(subclips, folder=folder,
                                              log=self.log_line.emit)
                    probed = select_to_target(subclips, self.target_minutes,
                                              log=self.log_line.emit)
                if self.music_path and self.beat_sync and probed:
                    beats_info = detect_beats(self.music_path, log=self.log_line.emit)
                    if beats_info:
                        bpm, beats = beats_info
                        self.log_line.emit(f"Beats: {bpm:.1f} BPM, {len(beats)} marqueurs")
                        probed = snap_subclips_to_beats(probed, beats,
                                                        log=self.log_line.emit)
                for info in probed:
                    self.clip_found.emit(info)
                self.finished_scan.emit(len(probed), ko)
            except Exception as e:
                self.error.emit(str(e))

    class EncodeThread(QThread):
        log_line = Signal(str)
        progress_pct = Signal(int)
        done = Signal(int)

        def __init__(self, cmd, kdenlive_args, total_duration):
            super().__init__()
            self.cmd = cmd
            self.kdenlive_args = kdenlive_args
            self.total_duration = total_duration

        def run(self):
            if self.kdenlive_args:
                try:
                    generate_kdenlive(*self.kdenlive_args)
                    self.log_line.emit(f"Projet Kdenlive genere: {self.kdenlive_args[1]}")
                except Exception as e:
                    self.log_line.emit(f"Erreur Kdenlive: {e}")

            if self.cmd is None:
                self.done.emit(0)
                return

            self.log_line.emit("Commande: " + ' '.join(repr(a) if ' ' in a else a for a in self.cmd))
            try:
                proc = subprocess.Popen(self.cmd, stdout=subprocess.PIPE,
                                        stderr=subprocess.STDOUT, text=True,
                                        bufsize=1)
                time_re = re.compile(r'time=(\d+):(\d+):(\d+\.\d+)')
                for line in proc.stdout:
                    line = line.rstrip()
                    m = time_re.search(line)
                    if m and self.total_duration > 0:
                        h, mn, s = m.groups()
                        elapsed = int(h) * 3600 + int(mn) * 60 + float(s)
                        pct = min(100, int(elapsed / self.total_duration * 100))
                        self.progress_pct.emit(pct)
                    self.log_line.emit(line)
                proc.wait()
                self.done.emit(proc.returncode)
            except Exception as e:
                self.log_line.emit(f"Erreur: {e}")
                self.done.emit(1)

