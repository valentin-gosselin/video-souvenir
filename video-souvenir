    L.append(f'  <tractor id="{seq_uuid}" in="00:00:00.000" out="{total_tc}">')
    L.append(f'    <property name="kdenlive:uuid">{seq_uuid}</property>')
    L.append('    <property name="kdenlive:clipname">Sequence 1</property>')
    L.append('    <property name="kdenlive:sequenceproperties.hasAudio">1</property>')
    L.append('    <property name="kdenlive:sequenceproperties.hasVideo">1</property>')
    L.append(f'    <property name="kdenlive:sequenceproperties.tracksCount">{3 if music_path else 2}</property>')
    L.append(f'    <property name="kdenlive:sequenceproperties.documentuuid">{seq_uuid}</property>')
    L.append(f'    <property name="kdenlive:control_uuid">{seq_uuid}</property>')
    L.append('    <property name="kdenlive:producer_type">17</property>')
    L.append('    <property name="kdenlive:sequenceproperties.activeTrack">1</property>')
    L.append(f'    <property name="kdenlive:sequenceproperties.groups">{groups_json}</property>')
    L.append('    <track producer="black_track"/>')
    L.append('    <track producer="tractor0"/>')
    if music_path:
        L.append('    <track producer="tractor_music"/>')
    L.append('    <track producer="tractor1"/>')
    # Audio mix transitions
    L.append('    <transition id="transition0">')
    L.append('      <property name="a_track">0</property>')
    L.append('      <property name="b_track">1</property>')
    L.append('      <property name="mlt_service">mix</property>')
    L.append('      <property name="kdenlive_id">mix</property>')
    L.append('      <property name="internal_added">237</property>')
    L.append('      <property name="always_active">1</property>')
    L.append('      <property name="accepts_blanks">1</property>')
    L.append('      <property name="sum">1</property>')
    L.append('    </transition>')
    tidx = 1
    if music_path:
        tidx += 1
        L.append(f'    <transition id="transition_audio_music">')
        L.append('      <property name="a_track">0</property>')
        L.append(f'      <property name="b_track">{tidx}</property>')
        L.append('      <property name="mlt_service">mix</property>')
        L.append('      <property name="kdenlive_id">mix</property>')
        L.append('      <property name="internal_added">237</property>')
        L.append('      <property name="always_active">1</property>')
        L.append('      <property name="accepts_blanks">1</property>')
        L.append('      <property name="sum">1</property>')
        L.append('    </transition>')
    tidx += 1
    L.append(f'    <transition id="transition_video">')
    L.append('      <property name="a_track">0</property>')
    L.append(f'      <property name="b_track">{tidx}</property>')
    L.append('      <property name="mlt_service">qtblend</property>')
    L.append('      <property name="kdenlive_id">qtblend</property>')
    L.append('      <property name="internal_added">237</property>')
    L.append('      <property name="always_active">1</property>')
    L.append('      <property name="compositing">0</property>')
    L.append('    </transition>')
    L.append('  </tractor>')

    L.append('  <playlist id="main_bin">')
    L.append(f'    <property name="kdenlive:docproperties.documentid">{doc_id}</property>')
    L.append(f'    <property name="kdenlive:docproperties.uuid">{seq_uuid}</property>')
    L.append(f'    <property name="kdenlive:docproperties.opensequences">{seq_uuid}</property>')
    L.append(f'    <property name="kdenlive:docproperties.activetimeline">{seq_uuid}</property>')
    L.append('    <property name="kdenlive:docproperties.kdenliveversion">24.05.2</property>')
    L.append('    <property name="kdenlive:docproperties.version">1.1</property>')
    L.append('    <property name="xml_retain">1</property>')
    for idx, parent in enumerate(parents_in_order):
        dur_tc = sec_to_tc(parent['duration'])
        L.append(f'    <entry producer="producer{idx}" in="00:00:00.000" out="{dur_tc}"/>')
    L.append(f'    <entry producer="{seq_uuid}" in="00:00:00.000" out="{total_tc}"/>')
    L.append('  </playlist>')

    L.append(f'  <tractor id="maintractor" in="00:00:00.000" out="{total_tc}">')
    L.append('    <property name="kdenlive:projectTractor">1</property>')
    L.append(f'    <track in="00:00:00.000" out="{total_tc}" producer="{seq_uuid}"/>')
    L.append('  </tractor>')

    L.append('</mlt>')

    output_path.write_text('\n'.join(L), encoding='utf-8')


def run_cli(args):
    folder = Path(args.folder)
    if not folder.is_dir():
        print(f"Erreur: '{folder}' n'est pas un dossier", file=sys.stderr)
        return 1

    print(f"Scan de {folder}...")
    trim_strength = args.trim_strength if args.auto_trim else 0
    clips = scan_folder(folder, auto_trim=args.auto_trim, trim_strength=trim_strength,
                        target_minutes=args.target_minutes,
                        music_path=args.music_path, beat_sync=args.beat_sync)
    style = args.style
    custom_lut = args.custom_lut
    if not custom_lut:
        auto_lut = detect_folder_lut(folder)
        if auto_lut and style == 'neutral':
            print(f"LUT auto-detectee dans le dossier: {auto_lut} -> style=custom")
            style = 'custom'
            custom_lut = auto_lut
    if style == 'custom' and not custom_lut:
        print("Style=custom mais aucun --lut fourni ni .cube detecte, fallback neutre.",
              file=sys.stderr)
        style = 'neutral'
    if not clips:
        print("Aucune video lisible trouvee (ffprobe a echoue sur tous les fichiers).",
              file=sys.stderr)
        print("Si tu vois des erreurs 'libopenh264', swap ffmpeg-free vers ffmpeg:",
              file=sys.stderr)
        print("  sudo dnf swap ffmpeg-free ffmpeg --allowerasing", file=sys.stderr)
        return 1

    print(f"{len(clips)} clips trouves (ordre chronologique):")
    for c in clips:
        td = trimmed_duration(c)
        if td < c['duration'] - 0.05:
            print(f"  - {c['name']}  ({c['width']}x{c['height']}, {td:.1f}s [trimme de {c['duration']:.1f}s])")
        else:
            print(f"  - {c['name']}  ({c['width']}x{c['height']}, {c['duration']:.1f}s)")

    encoder = args.encoder
    if encoder == 'auto':
        encoder = detect_encoder()
        if not encoder:
            print("Aucun encoder HEVC disponible", file=sys.stderr)
            return 1
    print(f"Encoder: {encoder}")

    out_base = args.output or str(folder / f"souvenir-{datetime.datetime.now():%Y%m%d-%H%M%S}.mp4")

    max_w = max(c['width'] for c in clips)
    max_h = max(c['height'] for c in clips)
    max_w, max_h = cap_resolution(max_w, max_h, args.max_res)

    if args.preview:
        preview_path = str(Path(out_base).with_name(
            Path(out_base).stem + '-preview.mp4'))
        print(f"Preview: {preview_path} (style={style})")
        cmd = build_preview_cmd(clips, preview_path, encoder, max_w, max_h, args.fps,
                                style=style, custom_lut=custom_lut)
        if cmd is None:
            print("Aucun clip pour preview", file=sys.stderr)
            return 1
        result = subprocess.run(cmd)
        if result.returncode != 0:
            return result.returncode
        print(f"Termine: {preview_path}")
        return 0

    if args.mode in ('kdenlive', 'both'):
        kdenlive_path = Path(out_base).with_suffix('.kdenlive')
        print(f"Generation projet Kdenlive: {kdenlive_path} (style={style})")
        generate_kdenlive(clips, kdenlive_path, max_w, max_h, args.fps, args.gap_minutes,
                          style=style, custom_lut=custom_lut, music_path=args.music_path)

    if args.mode in ('render', 'both'):
        print(f"Encodage: {out_base} (style={style})")
        cmd = build_ffmpeg_cmd(clips, out_base, encoder, args.quality, max_w, max_h, args.fps,
                               style=style, custom_lut=custom_lut, music_path=args.music_path)
        result = subprocess.run(cmd)
        if result.returncode != 0:
            return result.returncode
        print(f"Termine: {out_base}")

    return 0


